@Library('tenable.common')
import com.tenable.jenkins.*
import com.tenable.jenkins.builds.*
import com.tenable.jenkins.Constants
import com.tenable.jenkins.common.Common

currentBuild.displayName += "@ pr_check_automation_tests"

properties([
    parameters([
        stringParam(name: 'FILE_PATH', defaultValue: 'nessus/tests/', description: 'File paths of tests separated by comma'),
		stringParam(name: 'SPECIFIC_TEST_OR_CLASS', defaultValue: '', description: 'Define if any specific test or class needs to be executed.'),
		stringParam(name: 'AUTOMATION_BRANCH', defaultValue: 'release', description: 'Automation branch'),
		stringParam(name: 'PACKAGE_URL', defaultValue: 'https://nexus.cloud.aws.tenablesecurity.com/repository/product-release/nessus/release/Nessus-release-el8.x86_64.rpm', description: 'Nexus package url'),
		stringParam(name: 'INSTANCE_COUNT', defaultValue: '1', description: 'Number of instances'),
		[$class: 'ExtendedChoiceParameterDefinition', name: 'License_Type', defaultValue: 'Nessus Manager', value: 'Nessus Manager,Nessus Pro,Nessus Home', type: 'PT_CHECKBOX', multiSelectDelimiter:',']
    ])
])


Common common = new Common(this)

String targetOS = "OracleLinux8"
String nessusFilePath = params.FILE_PATH ? params.FILE_PATH.replaceAll(' ', '') : "nessus/tests/"
String testClass = params.SPECIFIC_TEST_OR_CLASS ?: ""
String packageUrl = params.PACKAGE_URL ?: "https://nexus.cloud.aws.tenablesecurity.com/repository/product-release/nessus/release/Nessus-release-el8.x86_64.rpm"
String automationBranch = params.AUTOMATION_BRANCH ?: "release"
String insCount = params.INSTANCE_COUNT ?: "1"
Integer instanceCount = insCount as Integer
String licenseType = params.License_Type ?: 'Nessus Manager'

BuildParams defaultParams = new BuildParams(this)
defaultParams.pytestCreateHtmlReport = false
defaultParams.pytestOptions = '-p catium.plugins.xdist_variables --reruns=2 --reruns-delay=0 --capabilities \'{"idleTimeout": 900, "maxDuration": 2700}\'  --ignore=nessus/tests/api/scanner_health/test_scanner_health_endpoints.py'
defaultParams.pytestTestPaths = nessusFilePath.split(',')
defaultParams.retryCount = 0
defaultParams.timeout = 600
defaultParams.productName         = "Nessus"
defaultParams.teamName            = "QE-Nessus"
defaultParams.testCategory        = "REGR"
defaultParams.suiteType           = "CLI"
defaultParams.platform            = "OracleLinux8"

Map defaultVars = [
	"CAT_LOG_LEVEL_CONSOLE": "INFO",
	"CAT_LOG_LEVEL": "DEBUG",
	"CAT_NESSUS_CLI_LOCAL": "False"
]


Map defaultConfig = [
    'Nessus Manager': [
        OracleLinux8: [type: "manager", marker: "'nessus_manager'"],
    ],
    'Nessus Pro': [
        OracleLinux8: [type: "pro", marker: "'nessus_pro'"],
    ],
    'Nessus Home': [
        OracleLinux8: [type: "home", marker: "'nessus_home'"],
    ]
]

Map testsConfig = [:]

licenseType.split(',').each{ltype ->
    if (!defaultConfig.keySet().contains(ltype)){
        error "License Type - ${ltype} is not supported."
    }
    testsConfig.put(ltype, defaultConfig[ltype])
}


Map testers = [:]

testsConfig.each { String testType, OSConfig ->
    OSConfig.each { String os, config ->
        if (os == targetOS) {
            testers["${testType}_${os}"] = {
                node(Constants.DOCKERNODE) {
                    BuildsCommon buildsCommon = new BuildsCommon(this)
                    buildsCommon.cleanup()

                    withOnDemandTestEnv(
                        OS: 'oraclelinux8',
                        awsInstanceType: 'c5.xlarge',
                        instanceCount: instanceCount,
                        diskSize: 50,
                        playbookExtraVars: ['user_data_wait': '45', 'plugin_server_host': 'plugins-internal-prod.cloud.aws.tenablesecurity.com', 'plugin_server_api': "https://plugins-internal-prod.cloud.aws.tenablesecurity.com/keygen/json.generate.php"],
                        nessusType: "${config.type}",
                        packageUrl: packageUrl,
                        product: 'nessus',
                    )   {
                            echo "Nessus installed and running on IP ${TEST_ENV_IPS}"
                            stage("${testType}_Tests") {

                                    Map env_vars = defaultVars.clone()
                                    env_vars = [
                                        CAT_SITE            : 'manager',
                                        CAT_SSH_USERNAME    : 'qa',
                                        CAT_SSH_USE_SUDO    : 'true',
                                        CAT_NESSUS_CLI_LOCAL: 'false',
                                        CAT_TIO_URL         : 'qa-staging.cloud.aws.tenablesecurity.com',
                                        ]

                                    String pytestOptions = " -m ${config.marker} --xdist-hosts ${TEST_ENV_IPS}" + (testClass ? " -k '${testClass}'" : "")

                                    AutomationDirectBuild builder = new AutomationDirectBuild(this)
                                    common.copyProperties(defaultParams, builder.parameters)
                                    builder.parameters.pytestAWSAutomationRoleDuration = 36000
                                    builder.parameters.saucelabsCredentialsId = 'nessusUISauceLabs'
                                    builder.parameters.pytestAllowNoTests = true
                                    builder.parameters.pytestOptions += pytestOptions
                                    builder.parameters.setPytestParallelName("${config.type}")
                                    builder.parameters.setAutomationEnvironment(env_vars)
                                    builder.parameters.pytestSshAgents = ['ODE-privkey']
									builder.parameters.pytestRepositoryUrl = 'git@github.eng.tenable.com:Product/catium-nessus.git'
									builder.parameters.pytestBranch = automationBranch
                                    builder.execute(createNode: false)
                                }
                            }
                        }
                }
            }
        }
    }

parallel(testers)