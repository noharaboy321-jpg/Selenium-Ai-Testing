@Library('tenable.common')
import com.tenable.jenkins.*
import com.tenable.jenkins.builds.*
import com.tenable.jenkins.Constants
import com.tenable.jenkins.common.Common

currentBuild.displayName += "@ oraclelinux8_ui-scanning_2_release-next_saucelabs"
Common common = new Common(this)

String targetOS = "OracleLinux8"

BuildParams defaultParams = new BuildParams(this)
defaultParams.pytestCreateHtmlReport = false
defaultParams.pytestOptions = "-p catium.plugins.xdist_variables --reruns=2 --reruns-delay=0 --capabilities '{\"idleTimeout\": 15, \"maxDuration\": 45, \"buildTags \":[\"nessus\"]}' ${ignoredItemsString} --ignore=nessus/tests/api/scanner_health/test_scanner_health_endpoints.py --ignore=nessus/tests/ui/server"
defaultParams.pytestTestPaths = ["nessus/tests/ui/scans/test_create_launch_scanner_scans_on_controller.py", "nessus/tests/ui/scans/test_create_launch_user_defined_scans_on_controller.py", "nessus/tests/ui/scans/test_export_scan_results_page.py", "nessus/tests/ui/scans/test_packet_capture_settings.py", "nessus/tests/ui/scans/test_scans_main_page.py","nessus/tests/ui/scans/test_scans_on_remote_scanner.py", "nessus/tests/ui/scans/test_scans_user_permissions.py", "nessus/tests/ui/scans/test_create_launch_agent_scans_on_manager.py", "nessus/tests/ui/scans/test_cvss_score_on_scan_result_page.py", "nessus/tests/ui/scans/test_editing_of_agents_scans.py", "nessus/tests/ui/scans/test_host_snmpv3_credentials.py", "nessus/tests/ui/scans/test_host_ssh_credentials.py", "nessus/tests/ui/scans/test_host_window_credentials.py", "nessus/tests/ui/scans/test_cloud_services_credentials.py", "nessus/tests/ui/scans/test_credentials_and_restrictions_json.py", "nessus/tests/ui/scans/test_database_credentials.py", "nessus/tests/ui/scans/test_imported_scan_results_page.py", "nessus/tests/ui/scans/test_miscellaneous_credentials.py", "nessus/tests/ui/scans/test_patch_management_credentials.py", "nessus/tests/ui/scans/test_plaintext_auth_credentials.py", "nessus/tests/ui/scans/test_scan_compliance_page.py", "nessus/tests/ui/scans/test_scan_vulnerability_grouping.py", "nessus/tests/ui/scans/test_scanner_scan_validation.py", "nessus/tests/ui/scans/test_scans_dynamic_plugins_page.py", "nessus/tests/ui/scans/test_scans_mobile_page.py", "nessus/tests/ui/scans/test_scans_plugins_page.py", "nessus/tests/ui/scans/test_scans_scanner_editing.py", "nessus/tests/ui/scans/test_scans_with_scap_and_oval_auditing.py", "nessus/tests/ui/scans/test_ux_scans.py", "nessus/tests/ui/scans/test_validation_in_agents_scans.py", "nessus/tests/ui/scans/test_vulnerability_snoozing.py", "nessus/tests/ui/scans/test_created_scan_results_page.py"]
defaultParams.retryCount = 0
defaultParams.timeout = 1200
defaultParams.productName         = "Nessus"
defaultParams.teamName            = "QE-Nessus"
defaultParams.testCategory        = "REGR"
defaultParams.suiteType           = "UI"
defaultParams.platform            = "OracleLinux8"

Map defaultVars = [
	"CAT_LOG_LEVEL_CONSOLE": "INFO",
	"CAT_LOG_LEVEL": "DEBUG",
	"CAT_NESSUS_CLI_LOCAL": "False"
]


Map testsConfig = [
    'Nessus Manager': [
        OracleLinux8: [type: "manager", marker: "'nessus_manager and not real_agent and scanning and not browser_file_download'"],
    ],
    'Nessus Pro': [
        OracleLinux8: [type: "pro", marker: "'nessus_pro and scanning and not browser_file_download'"],
    ],
    'Nessus Home': [
        OracleLinux8: [type: "home", marker: "'nessus_home and scanning and not browser_file_download'"],
    ],
    'Nessus Expert': [
        OracleLinux8: [type: "expert", marker: "'nessus_expert and scanning and not browser_file_download'"],
    ]
]

Map testers = [:]

testsConfig.each { String testType, OSConfig ->
    OSConfig.each { String os, config ->
        if (os == targetOS) {
            testers["${testType}_${os}"] = {
                node(Constants.DOCKERNODE) {
                    BuildsCommon buildsCommon = new BuildsCommon(this)
                    buildsCommon.cleanup()

                    withOnDemandTestEnv(
                        OS: 'oraclelinux8',
                        awsInstanceType: 'c5.xlarge',
                        instanceCount: 5,
                        diskSize: 80,
                        playbookExtraVars: ['user_data_wait': '45', 'plugin_server_host': 'plugins-internal-prod.cloud.aws.tenablesecurity.com', 'plugin_server_api': "https://plugins-internal-prod.cloud.aws.tenablesecurity.com/keygen/json.generate.php"],
                        nessusType: "${config.type}",
                        packageUrl: 'https://nexus.cloud.aws.tenablesecurity.com/repository/product-release/nessus/release-next/Nessus-release-next-es8.x86_64.rpm',
                        product: 'nessus'
                    )   {
                            echo "Nessus installed and running on IP ${TEST_ENV_IPS}"
                            stage("${testType}_Tests") {

                                    Map env_vars = defaultVars.clone()
                                    env_vars = [
                                        CAT_SITE            : 'manager',
                                        CAT_SSH_USERNAME    : 'qa',
                                        CAT_SSH_USE_SUDO    : 'true',
                                        CAT_NESSUS_CLI_LOCAL: 'false',
                                        CAT_NESSUS_VERSION  : config.type
                                        ]

                                    AutomationDirectBuild builder = new AutomationDirectBuild(this)
                                    common.copyProperties(defaultParams, builder.parameters)
                                    builder.parameters.lambdatestCredentialsId = 'nessusLambdatest'
                                    builder.parameters.pytestAWSAutomationRoleDuration = 36000
                                    builder.parameters.pytestOptions += " -m ${config.marker} --xdist-hosts ${TEST_ENV_IPS}"
                                    builder.parameters.setPytestParallelName("${config.type}")
                                    builder.parameters.setAutomationEnvironment(env_vars)
                                    builder.parameters.pytestSshAgents = ['ODE-privkey']
                                    builder.execute(createNode: false)
                                }
                            }
                        }
                }
            }
        }
    }

parallel(testers)
